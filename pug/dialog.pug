extends ./_layout/main.pug
block vars
	- const title = 'DIALOG'
block contents
	.fc
		#g-dir
			each _ in Array(20)
				.h10
					button.fm.primary.open-dialog
						span.icon launch
						span OPEN
	j-dialog.vw30(p-x='center' p-y='top' p-height=20 p-btn.close='true' @cb-close='cbClose')
		div(slot='header')
			span.icon person
			span= 'INFO'.repeat(10)
		p= '0123456789'.repeat(500)
	script(type='module').
		import jQC from './js/jq/jqc.min.js'
		await jQC.import('j-dialog')
		const d = console.log
		globalThis.cbClose = function() {
			d('cbClose')
		}
		const [ $dia ] = jQC.bind('j-dialog')
		$dia.open(this)
		$('.open-dialog').click(function() {
			$dia.open(this)
		})
	style
		:scss
			#g-dir {
				display: grid;
				justify-items: center;
				grid-template-columns: repeat(3, 1fr);
				grid-auto-rows: 1fr;
				width: 100%;
				height: 200vh;
				gap: 0.5rem;
				padding: 0.5rem;
				overflow-y: auto;
				& > :nth-child(3n+1) { justify-self: start; }
				& > :nth-child(3n)	 { justify-self: end; }
			}
