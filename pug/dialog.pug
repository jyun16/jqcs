extends ./_layout/main.pug
block vars
	- const title = 'DIALOG'
block contents
	.fc
		#g-dir
			each _ in Array(20)
				.h10
					button.fm.primary.open-dialog
						span.icon launch
						span OPEN
	j-dialog(p-btn.close='true' @cb-close='cbClose')
		p HOGE
		p HOGE
		p HOGE
	script(type='module').
		import jQC from './js/jq/jqc.min.js'
		await jQC.import('j-dialog')
		const d = console.log
		globalThis.cbClose = function() {
			d('called cbClose', this.find('dialog').id())
		}
		const [ $dia1, $dia2 ] = jQC.bind('j-dialog')
		// $('#dia-2-open').click(() => { $dia2.open() })
		// $dia1.open()
		$('.open-dialog').click(function() {
			$dia1.open('hoge')
		})
	style
		:scss
			#g-dir {
				display: grid;
				justify-items: center;
				grid-template-columns: repeat(3, 1fr);
				grid-auto-rows: 1fr;
				width: 100%;
				height: 200vh;
				gap: 0.5rem;
				padding: 0.5rem;
				overflow-y: auto;
				& > :nth-child(3n+1) { justify-self: start; }
				& > :nth-child(3n)	 { justify-self: end; }
			}
			.dialog-anchor {
				anchor-name: --anchor
			}
