extends ./_layout/main.pug
block vars
	- const title = 'DIALOG'
block contents
	button.primary.open-confirm
		span.icon launch
		span OPEN
	j-confirm(p-x='center')
	script(type='module').
		import jQC from './js/jq/jqc.min.js'

		await jQC.import('j-dialog')
		await jQC.import('j-confirm')

		const d = console.log
		const [ $confirm ] = await jQC.bind('j-confirm').ready()
		$confirm.p.msg = 'hoge'
		$confirm.open('デフォルトメッセージ')
		$('.open-confirm').click(function() {
			$confirm.open('良いですか？そうですか')
		})
	style
		:scss
