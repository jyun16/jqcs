extends ./base.pug
block body
	#modal-bg
	-
		const menus = [
			{ label: 'Count', href: '/index.html', icon: 'home' },
			{ label: 'Pager', href: '/pager.html', icon: 'home' },
			{ label: 'Dialog', href: '/dialog.html', icon: 'home' },
			{ label: 'Forms', subs: [
				{ label: 'Forms', href: '/forms.html' },
				{ label: 'Form', href: '/form.html' },
			]},
		]
		const top_menus = {}
		const gen_top_menus = m => m.forEach(m => {
			if (m.href && m.href !== '/') top_menus[m.href] = m.label
			if (m.subs) gen_top_menus(m.subs)
		})
		gen_top_menus(menus)
	.fv
		header
			#header-left
				span#menu-open.icon menu
				a(href='/')
					img#logo(src='/favicon.ico')
				#top-menu
					each text, url in top_menus
						a(href=url, class=(currentPath === url ? 'current' : ''))= text
			#header-right
				.header-icon.circle-icon H
				.header-icon
					span#menu-right-open.icon more_vert
		#body.f
			dialog#menu
				each m in menus
					.item(href=m.href)
						.label
							if m.icon
								.icon= m.icon
							span= m.label
							if m.subs
								.sub-icon.icon
						if m.subs
							.sub-item-container
								each sub in m.subs
									.sub-item(href=sub.href)
										.label= sub.label
			main
				block contents
