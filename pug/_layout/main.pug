	script.
		const path = location.pathname
		$('#top-menu [href]').each(function() {
			const $this = $(this)
			if ($this.attr('href') === path) {
				$this.addClass('current')
			}
		})

		$('#menu-open').click(function() {
			const $menu = $('#menu')
			$menu[0].showModal()
			$menu.addClass('active')
		})
		$('#menu').on('click', '.item', function(e) {
			const $this = $(this)
			const $subs = $this.find('.sub-item-container')
			if ($subs.length) {
				e.preventDefault()
				$subs.toggleClass('active')
				$this.toggleClass('active')
			}
			else {
				const href = $this.attr('href')
				if (href) location.href = href
			}
		})
		$('#menu').on('click', '.sub-item', function(e) {
			e.stopPropagation()
			const href = $(this).attr('href')
			if (href) location.href = href
		})
		$('#menu [href]').each(function() {
			const $this = $(this)
			if ($this.attr('href') === path) {
				$this.addClass('current')
				$this.closest('.sub-item-container').addClass('active').parent().addClass('active')
			}
		})
		$('#menu-right-open').click(function() {
			const $menu = $('#menu-right')
			$menu[0].showModal()
			$menu.addClass('active')
		})

		$('dialog').click(function(e) {
			if (e.target != this) return
			closeMenu(this)
		})
		$('dialog').on('cancel', function(e) {
			e.preventDefault()
			closeMenu(this)
		})
		const closeMenu = el => {
			if (!el.classList.contains('active')) return
			el.classList.remove('active')
			el.addEventListener('transitionend', () => { el.close() }, { once: true })
		}
	style
		:scss
