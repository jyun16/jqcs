pug
	j-dialog(p-btn.close=false)
		p {{ msg }}
		div(slot='footer')
			button.secondary(@click='close') Cancel
			button.primary(@click='close' autofocus) OK
p
	{
		msg: 'HOGE'
	}
head
	const d = console.log
init
	this.render()
	const $dia = jQC.bind('j-dialog', this)
	$dia.open()
	this.$dia = $dia
methods
	open(msg) {
		this.p.msg = msg
		this.render()
		this.$dia.open()
	}
scss
